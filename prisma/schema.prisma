generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// This schema maps the existing DuoCards PostgreSQL tables. It intentionally
// contains no connection string and no environment-specific value.

model User {
  id                Int                @id @default(autoincrement())
  email             String             @unique
  password          String
  googleId          String?            @unique
  facebookId        String?            @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  nickname          String             @default("User")
  locale            String             @default("cs")
  emailVerified     Boolean            @default(true)
  coins             Int                @default(100)
  lastDailyReward   DateTime?
  aiGenerations     AiGeneration[]
  flashcardSets     FlashcardSet[]
  words             Word[]
  completionRewards CompletionReward[]
  coinTransactions  CoinTransaction[]
  studySessions     StudySession[]
  studyReviews      StudyReview[]
  passwordResets    PasswordResetToken[]
  liveGames         LiveGame[]
  liveSessions      LiveSession[]

  @@map("users")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model PendingRegistration {
  id                      Int      @id @default(autoincrement())
  email                   String   @unique
  password                String
  nickname                String
  locale                  String   @default("cs")
  createdAt               DateTime @default(now())
  verificationCode        String
  verificationCodeExpires DateTime

  @@map("pending_registrations")
}

model RegistrationAttempt {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique
  email     String
  password  String
  nickname  String
  locale    String   @default("cs")
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
  @@map("registration_attempts")
}

model FlashcardSet {
  id             Int      @id @default(autoincrement())
  name           String
  userId         Int
  fromLanguage   String?
  toLanguage     String?
  isAIGenerated  Boolean  @default(false)
  tags           String[] @default([])
  isPublic       Boolean  @default(false)
  publicCode     String?  @unique
  joinedFromCode String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  words          Word[]
  studySessions  StudySession[]
  studyReviews   StudyReview[]

  @@map("flashcard_sets")
}

model Word {
  id             Int           @id @default(autoincrement())
  word           String
  translation    String
  difficulty     Int           @default(1)
  userId         Int
  flashcardSetId Int?
  pronunciation  String?
  imageId        Int?          @unique
  audioId        Int?          @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  reviewIntervalDays Int       @default(0)
  reviewEase         Int       @default(220)
  reviewStreak       Int       @default(0)
  reviewCount        Int       @default(0)
  correctReviewCount Int       @default(0)
  lapseCount         Int       @default(0)
  lastReviewedAt     DateTime?
  nextReviewAt       DateTime?
  audio          WordAudio?    @relation(fields: [audioId], references: [id])
  flashcardSet   FlashcardSet? @relation(fields: [flashcardSetId], references: [id], onDelete: Cascade)
  image          WordImage?    @relation(fields: [imageId], references: [id])
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  studyReviews   StudyReview[]

  @@index([userId, nextReviewAt])
  @@index([flashcardSetId, nextReviewAt])
  @@map("words")
}

model WordImage {
  id        Int      @id @default(autoincrement())
  dataUrl   String
  mimeType  String   @default("image/png")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  word      Word?

  @@map("word_images")
}

model WordAudio {
  id        Int      @id @default(autoincrement())
  dataUrl   String
  mimeType  String   @default("audio/mpeg")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  word      Word?

  @@map("word_audio")
}

model AiGeneration {
  id        Int      @id @default(autoincrement())
  userId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("ai_generations")
}

model CompletionReward {
  id             Int      @id @default(autoincrement())
  userId         Int
  amount         Int
  flashcardSetId Int
  claimDate      DateTime? @db.Date
  studySessionId String?   @unique @db.Uuid
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  studySession   StudySession? @relation(fields: [studySessionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@unique([userId, flashcardSetId, claimDate])
  @@map("completion_rewards")
}

model StudySession {
  id                String            @id @default(uuid()) @db.Uuid
  userId            Int
  flashcardSetId    Int
  wordIds           Int[]             @default([])
  totalWords        Int
  isFullSet         Boolean           @default(false)
  isScheduledReview Boolean           @default(true)
  reviewCount       Int               @default(0)
  correctCount      Int               @default(0)
  startedAt         DateTime          @default(now())
  completedAt       DateTime?
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcardSet      FlashcardSet      @relation(fields: [flashcardSetId], references: [id], onDelete: Cascade)
  reviews           StudyReview[]
  completionReward  CompletionReward?

  @@index([userId, startedAt])
  @@index([flashcardSetId, startedAt])
  @@map("study_sessions")
}

model StudyReview {
  id                 String       @id @default(uuid()) @db.Uuid
  sessionId          String       @db.Uuid
  userId             Int
  wordId             Int
  flashcardSetId     Int
  idempotencyKey     String       @unique @db.VarChar(64)
  rating             String       @db.VarChar(12)
  intervalBeforeDays Int
  intervalAfterDays  Int
  easeAfter          Int
  nextReviewAt       DateTime
  reviewedAt         DateTime     @default(now())
  session            StudySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  word               Word         @relation(fields: [wordId], references: [id], onDelete: Cascade)
  flashcardSet       FlashcardSet @relation(fields: [flashcardSetId], references: [id], onDelete: Cascade)

  @@index([sessionId, reviewedAt])
  @@index([userId, reviewedAt])
  @@index([wordId, reviewedAt])
  @@map("study_reviews")
}

model CoinTransaction {
  id           Int      @id @default(autoincrement())
  userId       Int
  amount       Int
  balanceAfter Int
  type         String   @db.VarChar(64)
  referenceId  String?  @db.VarChar(128)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("coin_transactions")
}

model LiveGame {
  id           Int              @id @default(autoincrement())
  hostUserId   Int
  roomCode     String
  setName      String?
  totalPlayers Int              @default(0)
  winnerName   String?
  startedAt    DateTime?
  endedAt      DateTime         @default(now())
  createdAt    DateTime         @default(now())
  host         User             @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  players      LiveGamePlayer[]

  @@index([hostUserId, createdAt])
  @@map("live_games")
}

model LiveGamePlayer {
  id         Int      @id @default(autoincrement())
  liveGameId Int
  name       String
  score      Int      @default(0)
  correct    Int      @default(0)
  total      Int      @default(0)
  eliminated Boolean  @default(false)
  isWinner   Boolean  @default(false)
  liveGame   LiveGame @relation(fields: [liveGameId], references: [id], onDelete: Cascade)

  @@index([liveGameId])
  @@map("live_game_players")
}

model LiveSession {
  id             String            @id @default(uuid())
  hostUserId     Int
  roomCode       String            @unique @db.VarChar(8)
  modeId         String            @db.VarChar(40)
  modeVersion    Int               @default(1)
  status         String            @default("LOBBY") @db.VarChar(20)
  sequence       Int               @default(0)
  settings       Json
  currentRoundId String?
  startedAt      DateTime?
  endedAt        DateTime?
  expiresAt      DateTime
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  host           User              @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  participants   LiveParticipant[]
  rounds         LiveRound[]

  @@index([hostUserId, createdAt])
  @@index([status, expiresAt])
  @@map("live_sessions")
}

model LiveParticipant {
  id         String       @id @default(uuid())
  sessionId  String
  nickname   String       @db.VarChar(40)
  role       String       @default("PLAYER") @db.VarChar(16)
  score      Int          @default(0)
  correct    Int          @default(0)
  total      Int          @default(0)
  streak          Int          @default(0)
  bestStreak      Int          @default(0)
  eliminated      Boolean      @default(false)
  practiceCorrect Int          @default(0)
  practiceTotal   Int          @default(0)
  joinedAt   DateTime     @default(now())
  lastSeenAt DateTime     @default(now())
  leftAt     DateTime?
  session    LiveSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answers    LiveAnswer[]

  @@unique([sessionId, nickname])
  @@index([sessionId, score])
  @@map("live_participants")
}

model LiveRound {
  id                 String       @id @default(uuid())
  sessionId          String
  sequence           Int
  state              String       @default("PENDING") @db.VarChar(20)
  prompt             String
  correctAnswer      String
  options            Json
  timeLimitSeconds   Int
  startedAt          DateTime?
  locksAt            DateTime?
  revealedAt         DateTime?
  createdAt          DateTime     @default(now())
  session            LiveSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answers            LiveAnswer[]

  @@unique([sessionId, sequence])
  @@index([sessionId, state])
  @@map("live_rounds")
}

model LiveAnswer {
  id                String          @id @default(uuid())
  roundId           String
  participantId     String
  answer            String
  normalizedAnswer  String
  isCorrect         Boolean
  points            Int             @default(0)
  responseTimeMs    Int
  idempotencyKey    String          @db.VarChar(64)
  createdAt         DateTime        @default(now())
  round             LiveRound       @relation(fields: [roundId], references: [id], onDelete: Cascade)
  participant       LiveParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([roundId, participantId])
  @@unique([participantId, idempotencyKey])
  @@index([roundId, createdAt])
  @@map("live_answers")
}
