# Runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info
# Enable only behind a trusted reverse proxy that overwrites forwarded headers.
TRUST_PROXY=false

# Database. Set one explicit URL; no value is committed here.
DATABASE_URL=
# Preferred outside production when a direct local PostgreSQL connection exists.
DIRECT_DATABASE_URL=

# Required in every environment. Use at least 32 random bytes.
AUTH_SECRET=

# Comma-separated browser origins. Native iOS requests do not need CORS.
CORS_ORIGINS=

# Development override. Production always forces Secure cookies.
COOKIE_SECURE=false

# The application defaults to Resend. This local example selects the console
# sink explicitly; console is rejected outside NODE_ENV=development.
VERIFICATION_EMAIL_MODE=console
RESEND_API_KEY=
# Either a mailbox or a complete display-name form, for example:
# DuoCards <notifications@duocards.xyz>
FROM_EMAIL=notifications@duocards.xyz

# Public web origin used in password-reset links. Use HTTPS with Resend/production;
# provide an origin only (no path, query, credentials, or fragment).
PUBLIC_APP_URL=http://localhost:3000
